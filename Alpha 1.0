)

button_re.grid(row= 5, column= 1, padx=1, pady=5)

button_reS= tk.Button(
    root,
    command=note_reS,
    text="Re#",
    fg="white",
    bg="blue",
    padx=10,
    pady=20
)

button_reS.grid(row=4, column=1, columnspan=2, padx=1)

