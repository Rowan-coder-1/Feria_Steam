button_mi.grid(row= 5, column=2, padx=1, pady=5)

button_fa = tk.Button(
    root,
    text= "Fa",
    command=note_fa,
    fg="white",
    bg="blue",
    padx=10,
    pady=20,
)

button_fa.grid(row=5, column=3, padx=1, pady=5)

button_faS = tk.Button(
    root,
    command=note_faS,
    text="Fa#",
    fg="white",
    bg="blue",
    padx=10,
    pady=20,
)

button_faS.grid(row=4, column=3, columnspan=2, padx=1, pady=5)

button_sol = tk.Button(
    root,
    text="Sol",
    command=note_sol,
    fg="white",
    bg="blue",
    padx=10,
    pady=20,
)

button_sol.grid(row=5, column=4, padx=1, pady=5)

button_solS = tk.Button(
    root,
    text="Sol#",
    command=note_solS,
    fg="white",
    bg="blue",
    padx=10,
    pady=20,
)

button_solS.grid(row=4, column=4, columnspan=2, padx=1, pady=5)

button_la = tk.Button(
    root, 
    text="La", 
    command=note_la,
    fg="white",     
    bg="blue",
    padx=10,
    pady=20,
)

button_la.grid(row= 5, column=5, padx=1, pady=5)

button_laS = tk.Button(
